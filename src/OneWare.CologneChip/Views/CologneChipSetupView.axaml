<controls:FlexibleWindow xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:OneWare.CologneChip.ViewModels"
             xmlns:controls="clr-namespace:OneWare.Essentials.Controls;assembly=OneWare.Essentials"
             xmlns:models="clr-namespace:OneWare.Essentials.Models;assembly=OneWare.Essentials"
             Title="{Binding Title}"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="OneWare.CologneChip.Views.CologneChipSetupView"
             x:DataType="viewModels:CologneChipSetupViewModel">
    
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="AttachedToVisualTree">
            <InvokeCommandAction Command="{Binding AttachedToVisualTreeCommand}" /> 
        </EventTriggerBehavior>
    </Interaction.Behaviors>
    
    <DockPanel LastChildFill="True" Margin="8">
        
        <StackPanel DockPanel.Dock="Bottom"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Right"
                   Classes="WindowButtons"
                   Margin="0,20,0,0" >
            <Button MinWidth="70" CornerRadius="4"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}">
                <TextBlock Text="Cancel" />
            </Button>
            <Button MinWidth="70" CornerRadius="4"
                    IsEnabled="{Binding CanInstall}"
                    Command="{Binding InstallCommand}"
                    Background="{DynamicResource ThemeAccentBrush}"
                    CommandParameter="{Binding $parent[Window]}">
                <TextBlock Text="Install" />
            </Button>
        </StackPanel>
        
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Spacing="2">
            <TextBlock Text="{Binding Header}" FontWeight="14"/>
            <TextBox Text="{Binding Description}" TextWrapping="Wrap" Opacity=".6"/>
        </StackPanel>
        
        <Panel DockPanel.Dock="Top">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RequiredPackages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.DataTemplates>
                        <DataTemplate x:DataType="models:IPackageState">
                            <Border Padding="8">
                                <StackPanel Orientation="Vertical" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Image Source="{Binding Package.IconUrl}"/>
                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{Binding Package.Name}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Package.Description}" Opacity=".6" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <ProgressBar Minimum="0" Maximum="1" 
                                                 Value="{Binding Progress}" 
                                                 IsVisible="{Binding IsIndeterminate}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.DataTemplates>
                </ItemsControl>
            </ScrollViewer>
            <controls:Spinner IsVisible="{Binding IsLoading}" Width="32" Height="32"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="Oops, something went wrong. Please try again later." Opacity=".5"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding LoadingFailed}"/>
        </Panel>
        
    </DockPanel>
</controls:FlexibleWindow>
